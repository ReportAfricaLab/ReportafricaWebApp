{
  "name": "reportafrica",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@9.6.7",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "dev:api": "turbo run dev --filter=@reportafrica/api",
    "dev:web": "turbo run dev --filter=@reportafrica/web",
    "dev:admin": "turbo run dev --filter=@reportafrica/admin",
    "dev:gov": "turbo run dev --filter=@reportafrica/gov-dashboard",
    "dev:mobile": "cd apps/mobile && npm start"
  },
  "devDependencies": {
    "@swc/helpers": "^0.5.15",
    "turbo": "^2.1.0"
  }
}
